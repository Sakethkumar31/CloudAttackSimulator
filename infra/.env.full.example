# CALDERA
CALDERA_IMAGE=mitre/caldera:latest
CALDERA_URL=http://caldera:8888
CALDERA_API_KEY=replace_with_caldera_api_key

# NEO4J (docker service in this stack)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_neo4j_password

# Dashboard auth
DASHBOARD_USER=socadmin
DASHBOARD_PASS=replace_with_dashboard_password
FLASK_SECRET_KEY=change_this_secret

# Optional AI tutor
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
