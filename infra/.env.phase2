# CALDERA Configuration
# For local Docker setup, CALDERA runs in container so use internal service name
CALDERA_URL=http://caldera:8888

# CALDERA API Key - get from caldera.local.yml or CALDERA UI after first startup
CALDERA_API_KEY=your_api_key_here

# Neo4j Configuration
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Dashboard Configuration
DASHBOARD_USER=socadmin
DASHBOARD_PASS=your_dashboard_password_here
ALLOW_MULTI_USER=1

# Optional: OpenAI for AI tutor features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Flask Session Key
FLASK_SECRET_KEY=redops_secure_key
